# Node.js 服务端环境变量示例
# 使用方式：复制此文件为 .env.development / .env.test / .env.production
# 这些文件不会被提交到 git（已在 .gitignore 中忽略），.env.example 会提交
#
# 运行方式：
#   pnpm dev          → 加载 env/.env.development
#   pnpm dev:test     → 加载 env/.env.test
#   pnpm start        → 加载 env/.env.production
#   pnpm start:test   → 加载 env/.env.test

# 服务监听端口
PORT=4000

# 运行环境（由脚本通过 cross-env 注入，此处仅作记录）
NODE_ENV=development

# JWT 密钥（生产环境请使用足够长的随机字符串）
JWT_SECRET=change_me_in_production_must_be_long_random_string

# JWT 过期时间
JWT_EXPIRES_IN=7d

# 允许跨域的来源（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# MySQL 数据库连接（Prisma）
# 格式：mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/mydb"
